	"devDependencies": {
		"@commitlint/cli": "20.5.3",
		"@commitlint/config-conventional": "20.5.3",
		"@commitlint/config-lerna-scopes": "20.4.3",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lerna": "9.0.7",
		"taze": "19.14.1"
	},
	"overrides": {
		"lerna": {
			"js-yaml": "4.3.0",
			"tar": "7.5.19"
		}
	}
}
